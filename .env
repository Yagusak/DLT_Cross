# Пример конфигурации для локального test-network из fabric-samples
CHANNEL=mychannel
CCNAME=paycc
LABEL=paycc_1.0
SEQUENCE=1
VERSION=1.0
ORDERER=orderer.example.com:7050
ORG1_PEER=peer0.org1.example.com:7051
ORG2_PEER=peer0.org2.example.com:9051
TLS_ENABLED=true
TLS_CA=/etc/hyperledger/fabric/tls/ca.crt
ADMIN_MSP=/tmp/adminmsp
CC_PATH=/opt/cc/pay-basic
CORE_PEER_LOCALMSPID=Org1MSP
